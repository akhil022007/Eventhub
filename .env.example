# Copy to .env for local dev:  cp .env.example .env
# (Docker Compose sets DATABASE_URL for the app itself; set-up.sh generates SESSION_SECRET.)

# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eventhub?schema=public"

# Secret used to sign the session cookie. REQUIRED — the app won't start without it.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"

# NODE_ENV and PORT are provided by the runtime (Docker / Render) — no need to set these.
